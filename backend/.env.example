AI_MODE=api
AI_PROVIDER=claude
CLAUDE_API_KEY=sk-ant-...

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/teaching_platform
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

USE_CACHE=true
CACHE_TTL=3600

LOCAL_MODEL_NAME=mistral:latest
LOCAL_BASE_URL=http://localhost:11434

# Email / SMTP (для восстановления пароля)
# Gmail: порт 465 + USE_TLS=true, или порт 587 + USE_TLS=false (STARTTLS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true

# URL фронтенда — используется в ссылке для сброса пароля
FRONTEND_URL=http://localhost:5173
