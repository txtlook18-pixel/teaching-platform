# ============================================================
# PRODUCTION ENVIRONMENT — AI Teaching Platform
# ============================================================
# 1. Скопируй этот файл: cp .env.prod.example .env.prod
# 2. Заполни реальными значениями
# 3. НИКОГДА не коммить .env.prod в git!
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=teaching_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# --- JWT Security ---
# Сгенерируй: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- AI Provider (выбери один режим) ---

# Вариант 1: Claude API (рекомендуется для диплома)
AI_MODE=api
AI_PROVIDER=claude
CLAUDE_API_KEY=sk-ant-...

# Вариант 2: GitHub Models (бесплатно)
# AI_MODE=api
# AI_PROVIDER=openai
# GITHUB_TOKEN=github_pat_...

# Вариант 3: Локальная модель Ollama (после диплома, для production)
# AI_MODE=local
# LOCAL_MODEL_NAME=mistral:latest
# LOCAL_BASE_URL=http://ollama:11434

# --- Cache ---
USE_CACHE=true
CACHE_TTL=3600
